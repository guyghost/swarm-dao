{
  "name": "swarm-dao",
  "version": "0.1.4",
  "description": "Unified Swarm DAO — Multi-host AI agent governance (Pi, OpenCode, and beyond)",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "lint:fix": "biome check --write --unsafe .",
    "typecheck": "bun run --filter '*' typecheck",
    "graph:init": "bun tools/graph-engineering/graphctl.ts init",
    "graph:status": "bun tools/graph-engineering/graphctl.ts status",
    "graph:submit": "bun tools/graph-engineering/graphctl.ts submit",
    "graph:validate": "bun tools/graph-engineering/validate.ts",
    "graph:demo": "bun tools/graph-engineering/demo.ts",
    "graph:regression": "bun test packages/core/tests/graph-engineering.regression.test.ts tools/graph-engineering/tests/signal.test.ts",
    "improvement:validate": "bun tools/improvement-loop/validate.ts",
    "improvement:anchors": "bun tools/improvement-loop/anchors.ts",
    "improvement:regression": "bun test packages/core/tests/improvement-loop.machine.test.ts packages/core/tests/improvement-loop.arbitration.test.ts packages/core/tests/improvement-loop.frozen.test.ts packages/core/tests/improvement-loop.regression.test.ts",
    "improvement:demo": "bun tools/improvement-loop/demo.ts",
    "improvement:init": "bun tools/improvement-loop/improvementctl.ts init",
    "improvement:status": "bun tools/improvement-loop/improvementctl.ts status",
    "improvement:submit": "bun tools/improvement-loop/improvementctl.ts submit",
    "ci": "bun run setup-stubs && bun run lint && bun run typecheck && bun test && bun run build && bun run pack:pi",
    "pack:pi": "bun run --cwd packages/pi-adapter build && npm pack --workspace @guyghost/swarm-dao-pi-adapter --dry-run",
    "prepare": "husky && bun run setup-stubs && bun run build",
    "setup-stubs": "bash scripts/setup-stubs.sh",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.0.1",
    "husky": "^9.1.7",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "js-yaml": "^4.2.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "keywords": [
    "dao",
    "governance",
    "swarm",
    "agents",
    "pi",
    "opencode"
  ],
  "author": "guyghost",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guyghost/swarm-dao.git"
  },
  "bugs": {
    "url": "https://github.com/guyghost/swarm-dao/issues"
  },
  "homepage": "https://github.com/guyghost/swarm-dao#readme",
  "dependencies": {
    "typebox": "^1.3.1"
  }
}
