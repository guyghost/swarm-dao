{
  "name": "swarm-dao",
  "version": "0.1.0",
  "description": "Unified Swarm DAO — Multi-host AI agent governance (Pi, OpenCode, and beyond)",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "prepare": "bun run build",
    "changeset": "changeset",
    "release": "bun test && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@changesets/cli": "^2.31.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "keywords": [
    "dao",
    "governance",
    "swarm",
    "agents",
    "pi",
    "opencode"
  ],
  "author": "guyghost",
  "license": "MIT",
  "dependencies": {
    "typebox": "^1.1.38"
  }
}
