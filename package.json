{
  "name": "swarm-dao",
  "version": "0.1.4",
  "description": "Unified Swarm DAO — Multi-host AI agent governance (Pi, OpenCode, and beyond)",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "pack:pi": "bun run --cwd packages/pi-adapter build && npm pack --workspace @guyghost/swarm-dao-pi-adapter --dry-run",
    "prepare": "bun run setup-stubs && bun run build",
    "setup-stubs": "bash scripts/setup-stubs.sh",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "js-yaml": "^4.2.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "keywords": [
    "dao",
    "governance",
    "swarm",
    "agents",
    "pi",
    "opencode"
  ],
  "author": "guyghost",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guyghost/swarm-dao.git"
  },
  "bugs": {
    "url": "https://github.com/guyghost/swarm-dao/issues"
  },
  "homepage": "https://github.com/guyghost/swarm-dao#readme",
  "dependencies": {
    "typebox": "^1.3.1"
  }
}
