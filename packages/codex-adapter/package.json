{
  "name": "@guyghost/swarm-dao-codex-adapter",
  "version": "0.2.1",
  "description": "Swarm DAO governance adapter for OpenAI Codex — MCP server, native config.toml, and AGENTS.md",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "bin": {
    "swarm-dao-codex": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "config/mcp-config.toml",
    "AGENTS.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@guyghost/swarm-dao-core": "^0.4.0",
    "@guyghost/swarm-dao-mcp": "^0.2.1"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "keywords": [
    "swarm-dao",
    "codex",
    "openai",
    "codex-cli",
    "mcp",
    "dao",
    "governance",
    "multi-agent",
    "deliberation",
    "quality-gates"
  ],
  "author": "guyghost",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guyghost/swarm-dao.git",
    "directory": "packages/codex-adapter"
  },
  "bugs": {
    "url": "https://github.com/guyghost/swarm-dao/issues"
  },
  "homepage": "https://github.com/guyghost/swarm-dao#readme",
  "publishConfig": {
    "access": "public"
  }
}
