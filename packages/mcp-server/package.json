{
  "name": "@guyghost/swarm-dao-mcp",
  "version": "0.2.1",
  "description": "Swarm DAO Model Context Protocol server — exposes DAO governance tools to any MCP-compatible host (Copilot, Claude, Codex, …)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "swarm-dao-mcp": "./dist/cli.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@guyghost/swarm-dao-core": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0"
  },
  "keywords": [
    "swarm-dao",
    "mcp",
    "model-context-protocol",
    "dao",
    "governance",
    "multi-agent",
    "deliberation",
    "ai-agents",
    "quality-gates",
    "copilot",
    "claude",
    "codex"
  ],
  "author": "guyghost",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guyghost/swarm-dao.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/guyghost/swarm-dao/issues"
  },
  "homepage": "https://github.com/guyghost/swarm-dao#readme",
  "publishConfig": {
    "access": "public"
  }
}
