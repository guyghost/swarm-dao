{
  "name": "@swarm-dao/pi-adapter",
  "version": "0.1.0",
  "description": "Swarm DAO adapter for the Pi coding agent",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@swarm-dao/core": "^0.1.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guyghost/swarm-dao.git",
    "directory": "packages/pi-adapter"
  },
  "bugs": {
    "url": "https://github.com/guyghost/swarm-dao/issues"
  },
  "homepage": "https://github.com/guyghost/swarm-dao#readme",
  "publishConfig": {
    "access": "public"
  }
}