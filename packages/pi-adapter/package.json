{
  "name": "@guyghost/swarm-dao-pi-adapter",
  "version": "0.1.2",
  "description": "Swarm DAO adapter for the Pi coding agent — multi-agent governance tools, commands, and event hooks",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@guyghost/swarm-dao-core": "^0.1.2"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.1.0",
    "@earendil-works/pi-ai": ">=0.1.0",
    "typebox": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "dao",
    "governance",
    "swarm",
    "agents",
    "multi-agent",
    "ai",
    "extension"
  ],
  "author": "guyghost",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guyghost/swarm-dao.git",
    "directory": "packages/pi-adapter"
  },
  "bugs": {
    "url": "https://github.com/guyghost/swarm-dao/issues"
  },
  "homepage": "https://github.com/guyghost/swarm-dao#readme",
  "publishConfig": {
    "access": "public"
  }
}
