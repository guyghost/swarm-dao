{
  "name": "@guyghost/swarm-dao-cli",
  "version": "0.1.2",
  "description": "Swarm DAO standalone CLI",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
