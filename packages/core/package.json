      "types": "./dist/governance/index.d.ts",
      "import": "./dist/governance/index.js"
    },
    "./intelligence": {
      "types": "./dist/intelligence/index.d.ts",
      "import": "./dist/intelligence/index.js"
    },
    "./control": {
      "types": "./dist/control/index.d.ts",
      "import": "./dist/control/index.js"
    },
    "./delivery": {
      "types": "./dist/delivery/index.d.ts",
      "import": "./dist/delivery/index.js"
    },
    "./persistence": {
      "types": "./dist/persistence.d.ts",
      "import": "./dist/persistence.js"
